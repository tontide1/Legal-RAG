# Backend Settings
DATABASE_URL=postgresql://postgres:postgres@db:5432/law_assistant
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=law_assistant
REDIS_URL=redis://redis:6379/0

# Provider Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
JINA_API_KEY=
POPPLER_PATH=
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_INDEX_MODEL=qwen3:4b
OLLAMA_NUM_CTX=8192
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_MAX_RETRIES=2
OLLAMA_RETRY_DELAY_SECONDS=5

# Embedding Configuration (local SentenceTransformer)
EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL=huyydangg/DEk21_hcmute_embedding
EMBEDDING_DIM=768
EMBEDDING_DEVICE=cuda
DOCKER_EMBEDDING_DEVICE=cpu
EMBEDDING_MAX_TOKEN_SIZE=384
EMBEDDING_QUERY_INSTRUCTION="Instruct: Given a Vietnamese legal question, retrieve relevant legal passages that answer the question\nQuery: "

# LLM Configuration (OpenRouter model string)
LLM_MODEL=gemini-3.1-flash-lite
LLM_MAX_TOKENS=1024
GEMINI_MAX_RETRIES=6
INDEX_MAX_OUTPUT_TOKENS=4096

# Global Graph Build Provider
GRAPH_BUILD_PROVIDER_DEFAULT=ollama

# 9router Local Indexing
NINE_ROUTER_BASE_URL=http://host.docker.internal:20128/v1
NINE_ROUTER_API_KEY=your_9router_api_key_here
NINE_ROUTER_INDEX_MODEL=openrouter/gpt-oss-20b
NINE_ROUTER_TIMEOUT_SECONDS=60
NINE_ROUTER_MAX_RETRIES=2
NINE_ROUTER_RETRY_DELAY_SECONDS=3

# Optional LightRAG Graph UI overrides
# The default repo embedding model is local SentenceTransformer-only and cannot be
# called through rag-ui with EMBEDDING_BINDING=openai. Use the main app upload flow
# on port 3000 unless you intentionally configure a supported server-backed
# embedding model here.
RAG_UI_EMBEDDING_BINDING=openai
RAG_UI_EMBEDDING_BINDING_HOST=https://openrouter.ai/api/v1
RAG_UI_EMBEDDING_BINDING_API_KEY=
RAG_UI_EMBEDDING_MODEL=huyydangg/DEk21_hcmute_embedding
RAG_UI_EMBEDDING_DIM=768

# LightRAG Settings
LIGHTRAG_WORKING_DIR=./backend/data
LIGHTRAG_MAX_ASYNC=1
LIGHTRAG_EMBEDDING_MAX_ASYNC=2
LIGHTRAG_EMBEDDING_TIMEOUT=180
LIGHTRAG_MAX_PARALLEL_INSERT=1
LIGHTRAG_CHUNK_SIZE=300
LIGHTRAG_CHUNK_OVERLAP_SIZE=50
SUMMARY_LANGUAGE=Vietnamese
ENTITY_TYPES=["Văn bản pháp luật", "Điều khoản", "Cơ quan ban hành", "Đối tượng áp dụng", "Thời hạn", "Khái niệm pháp lý", "Phạm vi áp dụng", "Trách nhiệm", "Ngoại lệ", "Điều kiện áp dụng", "Chủ thể có thẩm quyền", "Phương tiện giao thông", "Người tham gia giao thông", "Hành vi bị cấm", "Yêu cầu an toàn", "Giấy phép / chứng chỉ", "Dịch vụ hỗ trợ giao thông", "Kết cấu hạ tầng giao thông", "Hình thức xử phạt", "Hành vi vi phạm"]

# Hybrid Query Settings
HYBRID_MAX_HISTORY_MESSAGES=8
HYBRID_TOP_K=5
HYBRID_CHUNK_TOP_K=10
HYBRID_ANCHOR_CHUNK_LIMIT=3
HYBRID_BUCKET_CHUNK_LIMIT=2
JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual
JINA_RERANK_BASE_URL=https://api.jina.ai/v1/rerank
HYBRID_ENABLE_RERANK=true
